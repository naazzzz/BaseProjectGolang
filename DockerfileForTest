FROM golang:1.25.1-alpine

WORKDIR /application

RUN apk add --no-cache gcc musl-dev
ENV CGO_ENABLED=1

# Копируем go.mod и go.sum для кэширования зависимостей
COPY go.mod go.sum ./
RUN go mod download

# Устанавливаем современные инструменты для анализа покрытия и JUnit
RUN go install gotest.tools/gotestsum@latest && \
    go install github.com/boumenot/gocover-cobertura@latest && \
    echo "gotestsum and gocover-cobertura installed successfully" || { echo "Failed to install tools"; exit 1; }

# Копируем весь код
COPY . .

RUN go build -o /usr/local/bin/main ./cmd/app

# Запускаем тесты, генерируем отчеты в формате Cobertura и JUnit
CMD ["sh", "-c", "mkdir -p /application/coverage && \
    gotestsum --junitfile=/application/coverage/junit-report.xml \
              --format=standard-verbose \
              -- -covermode=atomic \
                 -coverprofile=/application/coverage/coverage.out \
                 -coverpkg=./... \
                 ./test/... && \
    gocover-cobertura < /application/coverage/coverage.out > /application/coverage/coverage.xml || true && \
    go tool cover -func=/application/coverage/coverage.out | grep total: || true && \
    echo 'All reports (JUnit + Cobertura + summary) generated successfully';"]